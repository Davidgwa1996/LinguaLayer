<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#E2E8F0"
    android:padding="4dp">

    <!-- Active Language Toolbar overlay bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="#1E293B"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/activeLanguageText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Translate: English ➔ Chinese"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnVoiceInput"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎙️ Mic"
            android:textSize="11sp"
            android:layout_marginEnd="6dp"
            android:backgroundTint="#475569"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnQuickTranslate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Translate ✨"
            android:textStyle="bold"
            android:textSize="11sp"
            android:backgroundTint="#F59E0B"
            android:textColor="#1E293B" />
    </LinearLayout>

    <!-- Standard mock key letters grid inside custom keyboard views -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:gravity="center">
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Q" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="W" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="E" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Y" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="U" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="I" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="O" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="P" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="A" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="D" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="F" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="G" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="H" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="J" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="K" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="L" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⇧" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Z" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="X" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="C" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="V" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="B" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="N" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="M" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⌫" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
    </LinearLayout>

    <!-- Space bar and bottom tools actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="?123" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="160dp" android:layout_height="wrap_content" android:text="SPACE BAR" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="➔" android:layout_margin="2dp" style="?android:attr/buttonStyleSmall" />
    </LinearLayout>
</LinearLayout>
