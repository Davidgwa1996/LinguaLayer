rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /rooms/{roomId} {
      allow create: if request.auth != null && request.resource.data.customerUid == request.auth.uid;
      
      allow read: if request.auth != null && (
        resource.data.customerUid == request.auth.uid ||
        resource.data.agentUid == request.auth.uid ||
        resource.data.status == 'waiting_for_agent' ||
        (request.auth.token != null && request.auth.token.email == 'njaudavid5@gmail.com')
      );
      
      allow update: if request.auth != null && (
        resource.data.customerUid == request.auth.uid ||
        resource.data.agentUid == request.auth.uid ||
        (resource.data.status == 'waiting_for_agent' && request.resource.data.status == 'active' && request.resource.data.agentUid == request.auth.uid) ||
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'customerUid', 'agentUid', 'created', 'createdAt'])) ||
        (request.auth.token != null && request.auth.token.email == 'njaudavid5@gmail.com')
      );
      
      match /messages/{messageId} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/rooms/$(roomId)).data.customerUid == request.auth.uid ||
          get(/databases/$(database)/documents/rooms/$(roomId)).data.agentUid == request.auth.uid ||
          (request.auth.token != null && request.auth.token.email == 'njaudavid5@gmail.com') ||
          get(/databases/$(database)/documents/rooms/$(roomId)).data.status == 'waiting_for_agent'
        );
        allow create: if request.auth != null && (
          get(/databases/$(database)/documents/rooms/$(roomId)).data.customerUid == request.auth.uid ||
          get(/databases/$(database)/documents/rooms/$(roomId)).data.agentUid == request.auth.uid ||
          (request.auth.token != null && request.auth.token.email == 'njaudavid5@gmail.com') ||
          get(/databases/$(database)/documents/rooms/$(roomId)).data.status == 'waiting_for_agent'
        ) && get(/databases/$(database)/documents/rooms/$(roomId)).data.status != 'ended';
        allow update, delete: if false; // messages cannot be edited or deleted
      }
    }
  }
}
