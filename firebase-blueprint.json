{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "name": { "type": "string", "maxLength": 100 },
        "preferredLanguage": { "type": "string", "maxLength": 100 },
        "languageCode": { "type": "string", "maxLength": 10 },
        "simpleModeEnabled": { "type": "boolean" },
        "voiceModeEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "preferredLanguage", "languageCode", "createdAt", "updatedAt"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Contact's language preferences for a specific user",
      "type": "object",
      "properties": {
        "contactName": { "type": "string", "maxLength": 100 },
        "preferredLanguage": { "type": "string", "maxLength": 100 },
        "languageCode": { "type": "string", "maxLength": 10 },
        "lastUsedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["contactName", "preferredLanguage", "languageCode", "lastUsedAt"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A conversation between users",
      "type": "object",
      "properties": {
        "participantIds": { "type": "array", "items": { "type": "string" }, "maxItems": 10 },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "mode": { "type": "string", "maxLength": 50 }
      },
      "required": ["participantIds", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single chat message with translations",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "originalText": { "type": "string", "maxLength": 2000 },
        "originalLanguage": { "type": "string", "maxLength": 100 },
        "originalLanguageCode": { "type": "string", "maxLength": 10 },
        "translations": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "originalText", "originalLanguage", "originalLanguageCode", "translations", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "users/{userId}/contacts/{contactId}": {
      "schema": { "$ref": "#/entities/Contact" },
      "description": "Contact language settings"
    },
    "conversations/{conversationId}": {
      "schema": { "$ref": "#/entities/Conversation" },
      "description": "Conversations list"
    },
    "conversations/{conversationId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages for a given conversation"
    }
  }
}
